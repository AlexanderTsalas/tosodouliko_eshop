# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (local development)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/
.idea/

# supabase
/supabase/.branches
/supabase/.temp
# Studio-managed SQL snippet files — per-user, written by Studio when
# saving queries in its UI. The repo's canonical query library lives in
# loadtest/probes/ (well-commented, intentional). Don't sync Studio's
# personal scratch space.
/supabase/snippets/

# load test results — large JSON per-run output, machine-specific.
# Path is loadtest/runs/<seed>/<scenario>/<env>/<timestamp>(-summary).json
/loadtest/runs/**/*.json

# Per-seed runtime artifacts (e.g. contention-target.json written by
# seed:contention so the scenario knows which variant to race for).
# Regenerated on every reseed, so committing would be churn.
/loadtest/lib/*-target.json

# Findings / planning docs that contain measured limits + security
# observations specific to this codebase. The TOOLING (scenarios, seeds,
# probes, helpers) is in the repo so future load testing is resumable,
# but the RESULTS + ranked weaknesses stay local — don't ship a recon
# roadmap with the codebase.
/loadtest/CAMPAIGN_FINDINGS.md
/loadtest/NEXT_PHASE_PLAN.md
