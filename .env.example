# =============================================================================
# Supabase
# =============================================================================
# From Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Stripe
# =============================================================================
# From Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_secret
# From Stripe dashboard → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Publishable key (safe for client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable

# =============================================================================
# External integrations (server-only)
# =============================================================================
COURIER_API_KEY=
COURIER_API_URL=
NEWSLETTER_API_KEY=
NEWSLETTER_API_URL=

# =============================================================================
# Cron (Vercel Cron → /api/cron/*)
# =============================================================================
# Shared bearer secret Vercel Cron sends as `Authorization: Bearer <value>`.
# REQUIRED in production — each cron route 500s if unset. Optional in dev
# (routes accept unauthenticated calls). Min 32 characters.
# Generate: openssl rand -base64 32
CRON_SECRET=

# =============================================================================
# MFA (admin two-factor)
# =============================================================================
# Server-side pepper for hashing MFA enrollment tokens + recovery codes.
# REQUIRED in production: internal-user onboarding mints an enrollment token,
# and every mint/validate/recovery call throws if this is missing or under 32
# characters. Must be the SAME value across every instance (and match the
# argument passed to the mint_mfa_enrollment_token SQL bootstrap helper).
# Generate: openssl rand -base64 32
MFA_TOKEN_PEPPER=

# =============================================================================
# Upstash Redis — rate limiting
# =============================================================================
# Required for production. Auth + checkout-code rate limiters live in
# src/lib/rate-limit/. Without these set, the limiter falls back to an
# in-memory map that doesn't survive multi-instance deploys or process
# restarts (and emits a warning at first use).
#
# Provision a Redis database at https://console.upstash.com/redis and
# copy the REST URL + REST token from the database details page.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=el
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR
